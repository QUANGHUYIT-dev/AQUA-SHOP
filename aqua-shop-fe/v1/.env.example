# Browser gọi qua Next.js proxy (tránh CORS) — không đổi khi deploy nếu dùng cùng domain
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Backend thật — chỉ dùng server-side (next.config rewrites)
# Dùng 127.0.0.1 thay vì localhost để tránh lỗi IPv6 trên Windows
API_PROXY_TARGET=http://127.0.0.1:8080

# Danh mục cha nav (mặc định: cay-thuy-sinh,ca-canh,phu-kien,be-ho-tu-ke)
# NEXT_PUBLIC_PARENT_CATEGORY_SLUGS=cay-thuy-sinh,ca-canh,phu-kien,be-ho-tu-ke
