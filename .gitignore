# =============================================================================
# AQUA Shop — Monorepo .gitignore
# aqua-shop-fe/v1 (Next.js) + aqua-shop-be/v1 (Spring Boot)
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & local config (KHÔNG commit — dùng file *.example làm mẫu)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# Spring Boot: cấu hình local có mật khẩu admin / override secret
**/application-local.yaml
!**/application-local.yaml.example

# Docker override local (mật khẩu, port tùy máy)
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# Frontend — Next.js (aqua-shop-fe/v1)
# -----------------------------------------------------------------------------
**/node_modules/
**/.next/
**/out/
**/.vercel/
**/.turbo/
**/tsconfig.tsbuildinfo

# Next.js standalone build output
**/.next/standalone/
**/.next/static/

# -----------------------------------------------------------------------------
# Backend — Java / Spring Boot / Maven (aqua-shop-be/v1)
# -----------------------------------------------------------------------------
**/target/
**/out/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Maven (giữ wrapper jar — chỉ bỏ qua file tạm)
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.project
.classpath
.settings/
bin/
*.sublime-workspace
*.sublime-project

# Cursor (giữ rules — bỏ cache/local)
.cursor/*
!.cursor/rules/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs & runtime
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Database & backup (dump dữ liệu thật — không đưa lên git)
# -----------------------------------------------------------------------------
*.sql
!**/src/main/resources/db/migration/*.sql
!**/src/test/resources/**/*.sql

# -----------------------------------------------------------------------------
# Upload / file tạm local
# -----------------------------------------------------------------------------
uploads/
handover/
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Test & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Certificates & keys
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.jks
*.keystore
credentials.json
secrets.json
